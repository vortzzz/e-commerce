# ── Servidor ──────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ───────────────────────────────────────
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA
JWT_EXPIRES_IN=7d

# ── Seguridad ─────────────────────────────────
BCRYPT_ROUNDS=10

# ── PostgreSQL (AWS RDS compatible) ───────────
DB_HOST=your-rds-instance.abc123xyz.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=nova_db
DB_USER=postgres
DB_PASSWORD=super_segura
# true/1 para RDS con SSL requerido; false/0 para local sin SSL
DB_SSL=true

# Opcional: tuning de pool
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# ── CORS ──────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# ── Servicio de pago ficticio ─────────────────
PAYMENT_SERVICE_URL=https://api.fakepay.nova/v1
PAYMENT_API_KEY=pk_test_tu_clave_aqui
